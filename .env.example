# Application
NODE_ENV=development
PORT=3000

# Database — default credentials match docker-compose.yml
DATABASE_URL=postgresql://shoppa:shoppa@localhost:5432/shoppa

# Redis
REDIS_URL=redis://localhost:6379

# HTTP
API_PREFIX=api/v1
# Comma-separated allow list. Leave unset in development to allow all origins.
# CORS_ORIGINS=https://shoppa.app,https://admin.shoppa.app

# Auth / JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-a-32-plus-char-random-string-for-development-only
JWT_REFRESH_SECRET=replace-with-a-different-32-plus-char-random-string-for-dev
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# OAuth — leave as `true` in development. Production must set `false`
# AND provide both audience values below — the env loader fails fast
# otherwise so a misconfigured prod can't accept arbitrary tokens.
OAUTH_DEV_MODE=true
# Required when OAUTH_DEV_MODE=false:
#   GOOGLE_OAUTH_CLIENT_ID=<your google oauth client id>
#   APPLE_OAUTH_AUDIENCE=<your apple service id>
GOOGLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_AUDIENCE=

# Uploads — bytes go to an S3-compatible service. Defaults match the
# MinIO container in docker-compose (no extra setup needed for local
# dev). For production, set S3_ENDPOINT to your provider (e.g.
# https://<account>.r2.cloudflarestorage.com for Cloudflare R2),
# update credentials, and set S3_PUBLIC_BASE_URL to the public host
# you serve files from.
UPLOADS_MAX_BYTES=10485760
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=shoppa-uploads
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_PUBLIC_BASE_URL=http://localhost:9000/shoppa-uploads
S3_FORCE_PATH_STYLE=true

# Email — Resend. Leaving RESEND_API_KEY empty makes the email worker log
# the rendered message instead of sending, which keeps the dev loop working
# without real credentials. For production: get a key at resend.com, verify
# a domain, and point RESEND_FROM_EMAIL at a mailbox on that domain. Until
# you have a domain, Resend's `onboarding@resend.dev` sender works but is
# capped to test-mode recipients.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Dev-only email redirect. Resend's test mode only permits sends to the
# account-owner's verified address. Set this to that address and every
# outgoing email (to any recipient) is rerouted there in development —
# the subject line is prefixed with `[→ <original>]` so you can still tell
# who the intended recipient was. IGNORED in production.
# DEV_EMAIL_REDIRECT=you@example.com

# Base for user-facing links embedded in emails (password reset, etc.).
# Should be whatever opens the Shoppa app on the user's device:
#   - `shoppa://`            production build or dev client (default)
#   - `http://localhost:3000/reset-password-fallback`  a web form you host
# For Expo Go testing, use a `exp+shoppa-mobile://` URL or just copy the
# token from the backend console line (APP_PUBLIC_URL is only used to
# build the clickable link in the email body).
APP_PUBLIC_URL=shoppa://
