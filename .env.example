# Application
NODE_ENV=development
PORT=3000

# Database — default credentials match docker-compose.yml
DATABASE_URL=postgresql://shoppa:shoppa@localhost:5432/shoppa

# Redis
REDIS_URL=redis://localhost:6379

# HTTP
API_PREFIX=api/v1
# Comma-separated allow list. Leave unset in development to allow all origins.
# CORS_ORIGINS=https://shoppa.app,https://admin.shoppa.app

# Auth / JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-a-32-plus-char-random-string-for-development-only
JWT_REFRESH_SECRET=replace-with-a-different-32-plus-char-random-string-for-dev
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# OAuth — leave as `true` in development. Production must set `false`
# AND provide both audience values below — the env loader fails fast
# otherwise so a misconfigured prod can't accept arbitrary tokens.
OAUTH_DEV_MODE=true
# Required when OAUTH_DEV_MODE=false:
#   GOOGLE_OAUTH_CLIENT_ID=<your google oauth client id>
#   APPLE_OAUTH_AUDIENCE=<your apple service id>
GOOGLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_AUDIENCE=

# Uploads — bytes go to an S3-compatible service. Defaults match the
# MinIO container in docker-compose (no extra setup needed for local
# dev). For production, set S3_ENDPOINT to your provider (e.g.
# https://<account>.r2.cloudflarestorage.com for Cloudflare R2),
# update credentials, and set S3_PUBLIC_BASE_URL to the public host
# you serve files from.
UPLOADS_MAX_BYTES=10485760
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=shoppa-uploads
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_PUBLIC_BASE_URL=http://localhost:9000/shoppa-uploads
S3_FORCE_PATH_STYLE=true
